rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function ingelogd() {
      return request.auth != null;
    }

    function rol() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol;
    }

    function isKashouderOfBeheerder() {
      return ingelogd() && (rol() == 'kashouder' || rol() == 'beheerder');
    }

    function isBeheerder() {
      return ingelogd() && rol() == 'beheerder';
    }

    match /users/{userId} {
      allow read: if ingelogd();
      allow write: if ingelogd() && (request.auth.uid == userId || isBeheerder());
      // NIEUW: kashouder mag specifiek het lottoSaldo-veld van een
      // ander lid bijwerken (storting registreren / automatisch
      // verrekenen — lib/firestore-payments.ts). Beheerder kon dit al
      // via de regel hierboven; deze regel dekt alleen de kashouder-rol.
      allow update: if isKashouderOfBeheerder()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lottoSaldo']);
    }

    match /users/{userId}/fcmTokens/{tokenId} {
      allow read, write: if ingelogd() && request.auth.uid == userId;
    }

    match /users/{userId}/notificationSettings/{docId} {
      allow read, write: if ingelogd() && request.auth.uid == userId;
    }

    match /betalingen/{betalingId} {
      allow read: if ingelogd();
      allow create: if ingelogd() && request.resource.data.userId == request.auth.uid;
      allow update: if isKashouderOfBeheerder();
      allow delete: if false;
    }

    match /kasmutaties/{mutatieId} {
      allow read: if ingelogd();
      allow create: if isKashouderOfBeheerder();
      allow update, delete: if false;
    }

    match /auditLog/{entryId} {
      allow read: if ingelogd();
      allow create: if ingelogd() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /paymentConfig/{docId} {
      allow read: if ingelogd();
      allow write: if isBeheerder();
    }

    // NIEUW: voor Naam vereniging / Standaard inleg (Beheer → Instellingen)
    match /verenigingConfig/{docId} {
      allow read: if ingelogd();
      allow write: if isBeheerder();
    }

    match /spelConfig/{docId} {
      allow read: if ingelogd();
      allow write: if isBeheerder();
    }

    match /prijsConfig/{docId} {
      allow read: if ingelogd();
      allow write: if isBeheerder();
    }

    match /seizoenen/{docId} {
      allow read: if ingelogd();
      allow write: if isBeheerder();
    }

    match /rondes/{docId} {
      allow read: if ingelogd();
      allow write: if isBeheerder();
    }

    match /trekkingen/{docId} {
      allow read: if ingelogd();
      allow write: if isBeheerder();
    }

    match /resultaten/{docId} {
      allow read: if ingelogd();
      allow write: if isBeheerder();
    }

    match /{document=**} {
      allow read: if ingelogd();
      allow write: if isBeheerder();
    }
  }
}
