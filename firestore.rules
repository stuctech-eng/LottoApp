rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: iedereen die ingelogd is mag lezen (voor ranglijst/leden),
    // maar alleen het eigen document bewerken
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Overige collecties: alleen lezen voor ingelogde gebruikers
    // Schrijven gebeurt later via kashouder/beheerder rollen (Fase 2)
    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
